# ── Runtime ──────────────────────────────────────────────────────────────────
HTTP_ADDR=:8080
LOG_LEVEL=info                  # debug | info | warn | error
SHUTDOWN_TIMEOUT=20s

# ── Auth ─────────────────────────────────────────────────────────────────────
# Set to false in production — allows all requests unauthenticated when true
DEVELOPMENT_AUTH=false
MEDIUM_CLIENT_ID=<your-medium-client-id>

# ── Database ──────────────────────────────────────────────────────────────────
REPOSITORY_DRIVER=postgres
DATABASE_URL=postgres://clawplane:clawplane@localhost:5432/clawplane?sslmode=disable
DB_MAX_OPEN_CONNS=20
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=30m
DB_CONN_MAX_IDLE_TIME=10m

# ── Redis / Queue ─────────────────────────────────────────────────────────────
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=                 # leave blank if no AUTH required
REDIS_QUEUE=clawplane:jobs

# ── Worker ────────────────────────────────────────────────────────────────────
JOB_MAX_ATTEMPTS=5
JOB_RETRY_BACKOFF=2s

# ── Kubernetes backend ────────────────────────────────────────────────────────
DEFAULT_INGRESS_HOST=apps.example.com
